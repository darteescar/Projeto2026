extends layout

block content
  .container.mt-4
    .row
      .col-lg-4.mb-4
        .card.shadow-sm.text-center.border-0.h-100
          .card-body.p-5
            img.rounded-circle.mb-3.shadow(src="/images/default-avatar.png" alt="User Profile Image" style="width: 150px; height: 150px; object-fit: cover;")
            h3.mb-1 Nome do Utilizador
            p.text-muted.mb-3 Estudante - 3º Ano
            button.btn.btn-outline-primary.btn-sm.w-100(type="button") Editar Perfil
          .card-footer.bg-transparent.border-0.text-start.px-4.pb-4
            p.mb-2
              i.bi.bi-envelope.me-2
              | email@exemplo.com
            p.mb-2
              i.bi.bi-calendar3.me-2
              | Membro desde: Setembro 2024
      
      .col-lg-8
        .card.shadow-sm.border-0
          .card-header.bg-white.pt-4.pb-3.border-bottom
            h4
              i.bi.bi-collection.me-2
              | Os Meus Recursos
          .card-body
            .table-responsive
              table.table.table-hover.align-middle
                thead.table-light
                  tr
                    th Título
                    th UC
                    th Tipo
                    th Downloads
                    th Ações
                tbody
                  // Exemplo com 1 registo
                  tr
                    td Formulario de Exame
                    td Fisica
                    td.span.badge.bg-secondary Formulário
                    td 45
                    td
                      a.btn.btn-sm.btn-primary.me-1(href="/recursos/detalhe/1" title="Ver")
                        i.bi.bi-eye
                      button.btn.btn-sm.btn-danger(data-bs-toggle="modal" data-bs-target="#deleteModal" title="Eliminar")
                        i.bi.bi-trash

  // Delete Confirmation Modal
  .modal.fade#deleteModal(tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true")
    .modal-dialog
      .modal-content
        .modal-header
          h5.modal-title#deleteModalLabel Confirmar Eliminação
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        .modal-body
          p Tem a certeza que pretende eliminar este recurso? Esta ação é irreversível.
        .modal-footer
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          form(action="/recursos/delete/1" method="POST")
            button.btn.btn-danger(type="submit") Eliminar