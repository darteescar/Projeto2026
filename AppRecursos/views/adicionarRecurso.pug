extends layout

block content
  .row.justify-content-center
    .col-lg-8
      .card.shadow-sm.border-0.mt-4
        .card-header.bg-primary.text-white.py-3
          h3.mb-0
            i.bi.bi-cloud-upload.me-2
            | Adicionar Novo Recurso
        .card-body.p-4
          form(action="/recursos/adicionar" method="POST" enctype="multipart/form-data")
            .mb-3
              label.form-label.fw-bold(for="titulo") Título/Nome do Recurso
              input#titulo.form-control(type="text" name="titulo" placeholder="Ex: Resumos Cap 1 a 4" required)
            
            .row.mb-3
              .col-md-6
                label.form-label.fw-bold(for="uc") Unidade Curricular (UC)
                input#uc.form-control(type="text" name="uc" placeholder="Ex: Eng. Web" required)
              .col-md-6
                label.form-label.fw-bold(for="ano") Ano Letivo
                input#ano.form-control(type="text" name="ano" placeholder="Ex: 2025/2026" required)

            .row.mb-3
              .col-md-6
                label.form-label.fw-bold(for="tipo") Tipo de Recurso
                select#tipo.form-select(name="tipo" required)
                  option(value="" disabled selected) Selecione uma opção...
                  option(value="slides") Slides
                  option(value="teste") Teste
                  option(value="video") Vídeo
                  option(value="dataset") Dataset
                  option(value="livros") Livros
                  option(value="aulas") Aulas Gravadas
                  option(value="resumos") Resumos
                  option(value="fichas") Fichas
                  option(value="formulario") Formulário
                  option(value="resolucao_teste") Resolução de Teste
                  option(value="resolucao_ficha") Resolução de Ficha
              .col-md-6
                label.form-label.fw-bold Visibilidade
                .mt-2
                  .form-check.form-check-inline
                    input#publica.form-check-input(type="radio" name="visibilidade" value="publica" checked)
                    label.form-check-label(for="publica") Pública
                  .form-check.form-check-inline
                    input#privada.form-check-input(type="radio" name="visibilidade" value="privada")
                    label.form-check-label(for="privada") Privada

            .mb-3
              label.form-label.fw-bold(for="descricao") Descrição
              textarea#descricao.form-control(name="descricao" rows="4" placeholder="Breve descrição do conteúdo do recurso...")
            
            .mb-4
              label.form-label.fw-bold(for="ficheiro") Ficheiro (PDF, ZIP, Imagem, etc.)
              input#ficheiro.form-control(type="file" name="ficheiro" required)

            hr.mb-4
            
            // Note: Autor e Data seriam preenchidos no Backend
            .d-flex.justify-content-end.gap-2
              a.btn.btn-outline-secondary(href="/recursos") Cancelar
              button.btn.btn-success(type="submit")
                i.bi.bi-plus-circle.me-1
                | Criar Recurso