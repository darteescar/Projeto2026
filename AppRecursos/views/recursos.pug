extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4.mt-3
    h2.mb-0 Catálogo de Recursos
    a.btn.btn-success(href="/recursos/adicionar")
      i.bi.bi-plus-lg.me-1
      | Novo Recurso

  .card.shadow-sm.border-0.mb-4
    .card-body
      form.row.g-3(action="/recursos" method="GET")
        .col-md-3
          label.form-label.fw-bold(for="search") Pesquisa Geral
          input#search.form-control(type="text" name="search" placeholder="Título, Autor..." value=query ? query.search : '')
        .col-md-2
          label.form-label.fw-bold(for="uc") Unidade Curricular (UC)
          input#uc.form-control(type="text" name="uc" placeholder="Ex: EW, BD" value=query ? query.uc : '')
        .col-md-2
          label.form-label.fw-bold(for="tipo") Tipo de Recurso
          select#tipo.form-select(name="tipo")
            option(value="") Todos
            option(value="slides") Slides
            option(value="teste") Teste
            option(value="video") Vídeo
            option(value="dataset") Dataset
            option(value="livros") Livros
            option(value="aulas") Aulas Gravadas
            option(value="resumos") Resumos
            option(value="fichas") Fichas
            option(value="formulario") Formulário
            option(value="resolucao_teste") Resolução de Teste
            option(value="resolucao_ficha") Resolução de Ficha
        .col-md-2
          label.form-label.fw-bold(for="ordem") Ordenar por:
          select#ordem.form-select(name="ordem")
            option(value="data_desc") Data (Mais recente)
            option(value="data_asc") Data (Mais antigo)
            option(value="estrelas_desc") Avaliação (Melhores)
        .col-md-3.d-flex.align-items-end
          button.btn.btn-primary.w-100(type="submit")
            i.bi.bi-filter.me-1
            | Aplicar Filtros

  .card.shadow-sm.border-0
    .card-body.p-0
      .table-responsive
        table.table.table-striped.table-hover.align-middle.mb-0
          thead.table-dark
            tr
              th Título
              th Autor
              th UC
              th Tipo
              th Data
              th Rating
              th Ações
          tbody
            // Exemplo local
            tr
              td.fw-bold Apontamentos Eng Web
              td Bruno Silva
              td EW
              td
                span.badge.bg-info.text-dark Resumos
              td 14/04/2026
              td
                i.bi.bi-star-fill.text-warning.me-1
                | 4.8
              td
                a.btn.btn-sm.btn-outline-primary.me-1(href="/recursos/detalhes/1" title="Visualizar/Detalhes")
                  i.bi.bi-eye
                a.btn.btn-sm.btn-outline-success(href="/recursos/download/1" title="Download")
                  i.bi.bi-download
            tr
              td.fw-bold Exame 2025 Normal
              td Maria João
              td EW
              td
                span.badge.bg-danger Teste
              td 13/04/2026
              td
                i.bi.bi-star-fill.text-warning.me-1
                | 5.0
              td
                a.btn.btn-sm.btn-outline-primary.me-1(href="/recursos/detalhes/2" title="Visualizar/Detalhes")
                  i.bi.bi-eye
                a.btn.btn-sm.btn-outline-success(href="/recursos/download/2" title="Download")
                  i.bi.bi-download