doctype html
html(lang="pt")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title
    link(rel="icon" type="image/png" href="/images/favicon.png")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
    link(rel="stylesheet", href="/stylesheets/style.css")
  body.bg-light.d-flex.flex-column.min-vh-100
    nav.navbar.navbar-expand-lg.navbar-dark.bg-primary.shadow-sm
      .container
        a.navbar-brand(href="/")
          i.bi.bi-journal-bookmark-fill.me-2
          | Recursos LEI
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
          span.navbar-toggler-icon
        .collapse.navbar-collapse#navbarNav
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href="/") Início
            li.nav-item
              a.nav-link(href="/recursos") Recursos
            li.nav-item
              a.nav-link(href="/recursos/adicionar") Adicionar Recurso
            li.nav-item
              a.nav-link(href="/sobre") Sobre
          ul.navbar-nav
            if id
              li.nav-item
                a.nav-link(href=`/users/perfil/${id}`)
                  i.bi.bi-person-circle.me-1
                  | Perfil
              li.nav-item
                a.nav-link(href="http://localhost:16001/logout")
                  i.bi.bi-box-arrow-right.me-1
                  | Logout
            else
              li.nav-item
                a.nav-link(href="http://localhost:16001/login")
                  i.bi.bi-box-arrow-in-right.me-1
                  | Login

    main.container.my-5
      block content

    footer.bg-dark.text-white.text-center.py-3.mt-auto
      .container
        p.mb-0 &copy; 2026 Plataforma Recursos LEI

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")