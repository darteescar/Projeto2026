extends layout

block content
  .row.justify-content-center
    .col-lg-8
      .card.shadow-sm.border-0.mt-4
        .card-header.bg-warning.py-3
          h3.mb-0.text-dark
            i.bi.bi-pencil-square.me-2
            | Editar Recurso
        .card-body.p-4
          form(action=`/recursos/editar/${recurso.id}` method="POST" enctype="multipart/form-data")
            .mb-3
              label.form-label.fw-bold(for="titulo") Título/Nome do Recurso
              input#titulo.form-control(type="text" name="titulo" value=recurso.titulo required)
            
            .row.mb-3
              .col-md-6
                label.form-label.fw-bold(for="uc") Unidade Curricular (UC)
                - var ucsArray = (typeof ucs !== 'undefined' && ucs) ? ucs : []
                - var hasCurrentUc = recurso.uc && ucsArray.indexOf(recurso.uc) !== -1
                select#uc.form-select(name="uc" required)
                  each val in ucsArray
                    option(value=val selected=(recurso.uc === val))= val
                  if recurso.uc && !hasCurrentUc
                    option(value=recurso.uc selected=true)= recurso.uc
                  option(value="outra") Outra
                
                .mt-2#outraContainer(style="display:none")
                  label.form-label.fw-bold(for="uc_outra") Especificar UC
                  input#uc_outra.form-control(type="text" name="uc_outra" placeholder="Escreva a UC que pretende" value=(showOutra ? recurso.uc : ''))

                script.
                  (function(){
                    var sel = document.getElementById('uc');
                    var cont = document.getElementById('outraContainer');
                    var inp = document.getElementById('uc_outra');
                    sel.addEventListener('change', function(e){
                      if(this.value === 'outra'){ cont.style.display='block'; inp.required = true; }
                      else { cont.style.display='none'; inp.required = false; }
                    });
                  })();
              .col-md-6
                label.form-label.fw-bold(for="ano") Ano Letivo
                input#ano.form-control(type="text" name="ano" value=recurso.ano required)

            .row.mb-3
              .col-md-6
                label.form-label.fw-bold(for="tipo") Tipo de Recurso
                - var tiposArray = (typeof tipos !== 'undefined' && tipos) ? tipos : []
                - var hasCurrentTipo = recurso.tipo && tiposArray.indexOf(recurso.tipo) !== -1
                select#tipo.form-select(name="tipo" required)
                  each val in tiposArray
                    option(value=val selected=(recurso.tipo === val))= val
                  if recurso.tipo && !hasCurrentTipo
                    option(value=recurso.tipo selected=true)= recurso.tipo
                  option(value="outro") Outro
                
                - var showOutro = (typeof tipos === 'undefined' || tipos.indexOf(recurso.tipo) === -1)
                .mt-2#outroContainer(style= showOutro ? "display:block" : "display:none")
                  label.form-label.fw-bold(for="tipo_outro") Especificar Tipo
                  input#tipo_outro.form-control(type="text" name="tipo_outro" placeholder="Escreva o Tipo que pretende" value=(showOutro ? recurso.tipo : ''))

                script.
                  (function(){
                    var selTipo = document.getElementById('tipo');
                    var contTipo = document.getElementById('outroContainer');
                    var inpTipo = document.getElementById('tipo_outro');
                    selTipo.addEventListener('change', function(e){
                      if(this.value === 'outro'){ contTipo.style.display='block'; inpTipo.required = true; }
                      else { contTipo.style.display='none'; inpTipo.required = false; }
                    });
                  })();
              .col-md-6
                label.form-label.fw-bold Visibilidade
                .mt-2
                  .form-check.form-check-inline
                    input#publica.form-check-input(type="radio" name="visibilidade" value="publico" checked=(recurso.visibilidade === 'publico'))
                    label.form-check-label(for="publica") Público
                  .form-check.form-check-inline
                    input#privada.form-check-input(type="radio" name="visibilidade" value="privado" checked=(recurso.visibilidade === 'privado'))
                    label.form-check-label(for="privada") Privado

            .mb-4
              label.form-label.fw-bold(for="ficheiro") Substituir Ficheiro (Opcional)
              .mb-2.text-primary
                i.bi.bi-file-earmark-text.me-1
                if recurso.ficheiro
                  span Ficheiro atual: #{recurso.ficheiro.originalName}
                else
                  span Sem ficheiro associado
              input#ficheiro.form-control(type="file" name="ficheiro")
              small.text-muted Se não selecionar novo ficheiro, mantém-se o atual.

            hr.mb-4
            
            .d-flex.justify-content-end.gap-2
              a.btn.btn-outline-secondary(href=`/recursos/detalhes/${recurso.id}`) Cancelar
              button.btn.btn-warning(type="submit")
                i.bi.bi-save.me-1
                | Guardar Alterações