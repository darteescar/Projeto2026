extends layout

block content
  .container.mt-4
    .row
      .col-lg-4.mb-4
        .card.shadow-sm.text-center.border-0
          .card-body.p-5
            img.rounded-circle.mb-3.shadow(src="/images/default-avatar.png" alt="User Profile Image" style="width: 150px; height: 150px; object-fit: cover;")
            h3.mb-3 #{user.nome} #{user.apelido}
            a.btn.btn-outline-primary.btn-sm.w-100(href=`/users/perfil/editar/${user.id}`) Editar Perfil
          .card-footer.bg-transparent.border-0.text-start.px-4.pb-4
            p.mb-2
              i.bi.bi-file-earmark-arrow-up.me-2
              | Número de contribuições: #{contribuicoes}
            p.mb-2
              i.bi.bi-envelope.me-2
              | #{user.email}
            p.mb-2
              i.bi.bi-calendar3.me-2
              | Membro desde: #{user.data_criacao ? new Date(user.data_criacao).toLocaleDateString('pt-PT') : 'N/D'}
      
      .col-lg-8
        .card.shadow-sm.border-0
          .card-header.bg-white.pt-4.pb-3.border-bottom
            h4
              i.bi.bi-collection.me-2
              | Os Meus Recursos
          .card-body.p-0
            .table-responsive
              table.table.table-striped.table-hover.align-middle.mb-0
                thead.table-dark
                  tr
                    th Título
                    th UC
                    th Ano
                    th Tipo
                    th Ações
                tbody
                  if recursos && recursos.length > 0
                    each rec in recursos
                      tr
                        td.fw-bold= rec.titulo
                        td= rec.uc
                        td= rec.ano || 'N/D'
                        td
                          span.badge.bg-info.text-dark= rec.tipo
                        td
                          a.btn.btn-sm.btn-outline-primary(href=`/recursos/detalhes/${rec.id}` title="Visualizar/Detalhes")
                            i.bi.bi-eye
                  else
                    tr
                      td(colspan="5").text-center.text-muted.py-4 Nenhum recurso associado a este utilizador