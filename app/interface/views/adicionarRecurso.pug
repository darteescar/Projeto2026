extends layout

block content
  .row.justify-content-center
    .col-lg-8
      .card.shadow-sm.border-0.mt-4
        .card-header.bg-primary.text-white.py-3
          h3.mb-0
            i.bi.bi-cloud-upload.me-2
            | Adicionar Novo Recurso
        .card-body.p-4
          form(action="/recursos/adicionar" method="POST" enctype="multipart/form-data")
            .mb-3
              label.form-label.fw-bold(for="titulo") Título/Nome do Recurso
              input#titulo.form-control(type="text" name="titulo" placeholder="Ex: Resumos Cap 1 a 4" required)
            
            .row.mb-3
              .col-md-6
                label.form-label.fw-bold(for="uc") Unidade Curricular (UC)
                - var ucsArray = (typeof ucs !== 'undefined' && ucs) ? ucs : []
                select#uc.form-select(name="uc" required)
                  option(value="" disabled selected) Selecione uma opção...
                  each val in ucsArray
                    option(value=val)= val
                  option(value="outra") Outra
                .mt-2#outraContainer(style="display:none")
                  label.form-label.fw-bold(for="uc_outra") Especificar UC
                  input#uc_outra.form-control(type="text" name="uc_outra" placeholder="Escreva a UC que pretende")

                script.
                  (function(){
                    var sel = document.getElementById('uc');
                    var cont = document.getElementById('outraContainer');
                    var inp = document.getElementById('uc_outra');
                    sel.addEventListener('change', function(e){
                      if(this.value === 'outra'){ cont.style.display='block'; inp.required = true; }
                      else { cont.style.display='none'; inp.required = false; }
                    });
                  })();
              .col-md-6
                label.form-label.fw-bold(for="ano") Ano Letivo
                input#ano.form-control(type="text" name="ano" placeholder="Ex: 2025/2026" required)

            .row.mb-3
              .col-md-6
                label.form-label.fw-bold(for="tipo") Tipo de Recurso
                - var tiposArray = (typeof tipos !== 'undefined' && tipos) ? tipos : []
                select#tipo.form-select(name="tipo" required)
                  option(value="" disabled selected) Selecione uma opção...
                  each val in tiposArray
                    option(value=val)= val
                  option(value="outro") Outro
                
                .mt-2#outroContainer(style="display:none")
                  label.form-label.fw-bold(for="tipo_outro") Especificar Tipo
                  input#tipo_outro.form-control(type="text" name="tipo_outro" placeholder="Escreva o Tipo que pretende")

                script.
                  (function(){
                    var selTipo = document.getElementById('tipo');
                    var contTipo = document.getElementById('outroContainer');
                    var inpTipo = document.getElementById('tipo_outro');
                    selTipo.addEventListener('change', function(e){
                      if(this.value === 'outro'){ contTipo.style.display='block'; inpTipo.required = true; }
                      else { contTipo.style.display='none'; inpTipo.required = false; }
                    });
                  })();
              .col-md-6
                label.form-label.fw-bold Visibilidade
                .mt-2
                  .form-check.form-check-inline
                    input#publica.form-check-input(type="radio" name="visibilidade" value="publico" checked)
                    label.form-check-label(for="publica") Pública
                  .form-check.form-check-inline
                    input#privada.form-check-input(type="radio" name="visibilidade" value="privado")
                    label.form-check-label(for="privada") Privada

            .mb-4
              label.form-label.fw-bold(for="ficheiro") Ficheiro (PDF, Imagem, etc.)
              input#ficheiro.form-control(type="file" name="ficheiro" required)

            hr.mb-4
            
            .d-flex.justify-content-end.gap-2
              a.btn.btn-outline-secondary(href="/recursos") Cancelar
              button.btn.btn-success(type="submit")
                i.bi.bi-plus-circle.me-1
                | Criar Recurso